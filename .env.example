# -----------------------------------------------------------------------------
# Supabase（Project Settings → API）
# -----------------------------------------------------------------------------
# 以下两项可安全出现在浏览器打包产物中，对应「匿名 / 登录用户」身份，RLS 仍约束数据访问。
NEXT_PUBLIC_SUPABASE_URL=https://你的项目.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=你的_anon_公钥

# -----------------------------------------------------------------------------
# 可选：仅服务端脚本（如 Admin、迁移、绕过 RLS 的任务）使用
# 切勿使用 NEXT_PUBLIC_ 前缀；切勿在 Client Component 或前端 bundle 中引用。
# -----------------------------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# MiniMax（服务端 AI provider）
# 使用 OpenAI-compatible API；切勿暴露到客户端。
# -----------------------------------------------------------------------------
MINIMAX_API_KEY=你的_minimax_api_key
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=M2-her
