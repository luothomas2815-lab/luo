{
  "name": "sleep-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:coach": "set E2E_COACH_FIXTURE=1&& playwright test tests/e2e/coach-prompt-fill.spec.ts",
    "test:e2e:coach:stream": "set E2E_COACH_FIXTURE=1&& playwright test tests/e2e/coach-stream-first-chunk.spec.ts",
    "test:e2e:coach:blocked": "set E2E_COACH_FIXTURE=1&& playwright test tests/e2e/coach-blocked-response.spec.ts",
    "test:e2e:coach:history": "set E2E_COACH_FIXTURE=1&& playwright test tests/e2e/coach-history-switch.spec.ts",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "next": "16.2.2",
    "openai": "^6.33.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
